{
  "name": "financial-api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "npm run build && node ./dist/bin/www",
    "start:dev": "nodemon -e .ts ./dist/bin/www",
    "migrate": "node-pg-migrate",
    "build": "tsc -p ."
  },
  "dependencies": {
    "body-parser": "^1.19.0",
    "cookie-parser": "~1.3.5",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "module-alias": "^2.2.2",
    "node-pg-migrate": "^5.8.1",
    "pg": "^8.4.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.17.0",
    "@types/cookie-parser": "^1.4.1",
    "@types/express": "^4.16.1",
    "@types/jest": "^24.0.12",
    "@types/node": "^12.0.0",
    "@types/pg": "^7.14.5",
    "httptypes": "file:../httpTypes",
    "jest": "^24.8.0",
    "nodemon": "^2.0.6",
    "ts-jest": "^24.0.2",
    "typescript": "^4.5.4"
  },
  "nodemonConfig": {
    "verbose": "true",
    "exec": "tsc -p . && node",
    "watch": [
      "src/**/*.ts"
    ],
    "ignore": [
      "test/*",
      "docs/*",
      "dist/*",
      "**/*.js",
      "**/*.ts.map"
    ],
    "delay": "2500"
  }
}
